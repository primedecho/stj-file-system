# Copy to `.env` and adjust as needed.

# Application environment: development | production
ENVIRONMENT=development

# Enable debug mode (SQL echo, demo data seeding when database is empty)
DEBUG=true

# SQLite (default — local development)
DATABASE_URL=sqlite:///./stj_file_system.db

# SQLite (Docker — set automatically in docker-compose.yml)
# DATABASE_URL=sqlite:////app/data/stj_file_system.db

# PostgreSQL (Docker — use with docker-compose.postgres.yml)
# DATABASE_URL=postgresql+psycopg://stj:stj@postgres:5432/stj_file_system

# Allowed frontend origins (JSON array)
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
